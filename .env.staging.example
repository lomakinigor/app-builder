# .env.staging.example — T-409
#
# Copy this file to .env.staging.local and fill in the values for your
# staging environment. Never commit real credentials.
#
# Usage:
#   source .env.staging.local && npm run test:e2e:staging:session
#
# Or export inline:
#   VITE_API_MODE=real \
#   VITE_API_BASE_URL=https://api-staging.example.com \
#   VITE_API_BEARER_TOKEN=... \
#   VITE_FEATURE_SHARING=true \
#   npm run test:e2e:staging:session

# ─── Core (required) ──────────────────────────────────────────────────────────

# Activate HTTP adapters instead of in-memory mocks.
VITE_API_MODE=real

# Base URL of the staging backend (no trailing slash).
VITE_API_BASE_URL=https://api-staging.example.com

# ─── Auth (optional) ──────────────────────────────────────────────────────────

# Bearer token sent in every API request as Authorization: Bearer <token>.
# Omit if the staging backend does not require auth.
VITE_API_BEARER_TOKEN=

# ─── Session correlation (recommended) ────────────────────────────────────────

# Run-level session id sent as X-Session-Id on every request.
# Auto-generated by scripts/staging-smoke.sh when using npm run test:e2e:staging:session.
# Override here to pin a known id for debugging a specific run.
# Format: smoke-<YYYYMMDDHHmm>-<4-hex>  e.g. smoke-202604231015-ab12
VITE_SESSION_ID=

# ─── Feature flags (required for SMOKE-002 and SMOKE-004) ────────────────────

# Enable sharing and collaboration UI (share button, invite panel, collaborator panel).
# Must be true for SMOKE-002 (POST /api/shares, GET /api/shares/:shareId) and
# SMOKE-004 (invite acceptance) to run. Tests are skipped when this is absent.
VITE_FEATURE_SHARING=true

# ─── MVP-critical endpoints covered by staging smoke ─────────────────────────
#
# SMOKE-001 (critical-real-backend.spec.ts):
#   POST /api/research/run
#   POST /api/spec/generate
#   POST /api/architecture/generate
#   POST /api/prompt-loop/first
#
# SMOKE-002 (collaboration-real-backend.spec.ts — requires VITE_FEATURE_SHARING=true):
#   POST /api/shares                              → ShareInfo
#   GET  /api/shares/:shareId                     → ResolvedShare
#   POST /api/shares/:shareId/invite              → InviteResult
#
# SMOKE-003 (collaboration-real-backend.spec.ts):
#   GET  /api/projects/:projectId/comments        → ArtifactComment[]
#   POST /api/projects/:projectId/comments        → ArtifactComment
#
# SMOKE-004 (collaboration-real-backend.spec.ts — requires VITE_FEATURE_SHARING=true):
#   GET  /api/invites/:inviteToken                → InviteInfo
#   POST /api/invites/:inviteToken/accept         → AcceptedInvite
#
# Not yet covered by staging smoke (backend not implemented):
#   GET  /api/projects/:projectId/collaborators   → ProjectCollaborator[]
#   PATCH  /api/collaborators/:id                 → ProjectCollaborator
#   DELETE /api/collaborators/:id                 → { success: true }
#   GET  /api/projects/:projectId/sharing-audit   → SharingAuditEvent[]
